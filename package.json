{
  "name": "vscode-edit-bdf",
  "displayName": "BDF Font Editor",
  "description": "A simple BDF font editor for Visual Studio Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "bdf",
    "bdf-font"
  ],
  "activationEvents": [
    "onLanguage:bdf-font"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "bdf-font",
        "aliases": [
          "BDF Font"
        ],
        "extensions": [
          ".bdf"
        ]
      }
    ],
    "grammars": [
      {
        "language": "bdf-font",
        "scopeName": "source.bdf",
        "path": "./syntaxes/bdf-font.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "edit-bdf.glyph-list",
        "displayName": "Glyph List",
        "selector": [
          {
            "filenamePattern": "*.bdf"
          }
        ]
      }
    ]
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsx build.mts",
    "watch": "tsx build.mts --watch"
  },
  "author": "friuli-jokyo",
  "repository": {
    "type": "git",
    "url": "https://github.com/friuli-jokyo/vscode-edit-bdf.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@types/node": "^25.6.0",
    "@types/unicode-name": "^1.1.0",
    "@types/vscode": "^1.115.0",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fontsource/unifont": "^5.2.5",
    "@lit-labs/virtualizer": "^2.1.1",
    "lit": "^3.3.2",
    "unicode-name": "^1.1.0"
  }
}